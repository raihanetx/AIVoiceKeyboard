<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎤 AI Voice Keyboard"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A73E8" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Keyboard not yet enabled. Tap 'Enable Keyboard' to proceed."
        android:textSize="16sp"
        android:textAlignment="center"
        android:textColor="#666666" />

    <Button
        android:id="@+id/btnEnableKeyboard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Enable Keyboard"
        android:textAllCaps="false"
        android:backgroundTint="#1A73E8" />

    <Button
        android:id="@+id/btnSelectKeyboard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Select Keyboard"
        android:textAllCaps="false"
        android:backgroundTint="#34A853" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Features:\n• Voice typing with Android Offline\n• Voice typing with Groq AI\n• English &amp; Bangla keyboards\n• Smart suggestions"
        android:textSize="14sp"
        android:textAlignment="center"
        android:textColor="#888888" />

</LinearLayout>
