<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⌨️ AI Keyboard"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1F2937" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Enable the keyboard below"
        android:textSize="16sp"
        android:textAlignment="center"
        android:textColor="#6B7280" />

    <Button
        android:id="@+id/btnEnableKeyboard"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="1. Enable Keyboard"
        android:textSize="16sp"
        android:backgroundTint="#3B82F6" />

    <Button
        android:id="@+id/btnSelectKeyboard"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="2. Select Keyboard"
        android:textSize="16sp"
        android:backgroundTint="#10B981" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="After enabling, open Messages or\nany app with text input"
        android:textSize="14sp"
        android:textAlignment="center"
        android:textColor="#9CA3AF" />

</LinearLayout>
