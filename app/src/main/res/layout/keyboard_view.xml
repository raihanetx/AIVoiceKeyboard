<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#E8EAED"
    android:paddingBottom="16dp">

    <!-- CONTAINER: Top Area (Toolbar + Suggestions + Voice) -->
    <LinearLayout
        android:id="@+id/topAreaContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 1. TOOLBAR -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Icons: Emoji, Clipboard, Credentials -->
            <ImageButton
                android:id="@+id/btnEmoji"
                style="@style/KeyboardToolbarButton"
                android:contentDescription="Emoji"
                android:src="@drawable/ic_smile" />

            <ImageButton
                android:id="@+id/btnClipboard"
                style="@style/KeyboardToolbarButton"
                android:contentDescription="Clipboard"
                android:src="@drawable/ic_clipboard" />

            <ImageButton
                android:id="@+id/btnCredentials"
                style="@style/KeyboardToolbarButton"
                android:contentDescription="Credentials"
                android:src="@drawable/ic_key" />

            <!-- Spacer to push settings/voice to the right -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Icons: Language, Settings, Mic -->
            <ImageButton
                android:id="@+id/btnLanguage"
                style="@style/KeyboardToolbarButton"
                android:contentDescription="Language"
                android:src="@drawable/ic_globe" />

            <ImageButton
                android:id="@+id/btnSettings"
                style="@style/KeyboardToolbarButton"
                android:contentDescription="Settings"
                android:src="@drawable/ic_settings" />

            <ImageButton
                android:id="@+id/btnVoice"
                style="@style/KeyboardToolbarButton"
                android:contentDescription="Voice"
                android:src="@drawable/ic_mic" />
        </LinearLayout>

        <!-- 2. SUGGESTION BAR (with Dividers) -->
        <LinearLayout
            android:id="@+id/suggestionBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:visibility="gone"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            tools:visibility="visible">

            <!-- Word 1 (Left) -->
            <TextView
                android:id="@+id/tvSugg1"
                style="@style/SuggestionWord"
                android:gravity="start"
                android:text="the" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:background="#1F000000" />

            <!-- Word 2 (Center) -->
            <TextView
                android:id="@+id/tvSugg2"
                style="@style/SuggestionWord"
                android:gravity="center"
                android:layout_weight="1"
                android:text="be" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:background="#1F000000" />

            <!-- Word 3 (Right) -->
            <TextView
                android:id="@+id/tvSugg3"
                style="@style/SuggestionWord"
                android:gravity="end"
                android:text="to" />
        </LinearLayout>

        <!-- 3. VOICE BAR (Initially Gone) -->
        <LinearLayout
            android:id="@+id/voiceBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:visibility="gone"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Language Chip -->
            <TextView
                android:id="@+id/tvVoiceLang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_grey"
                android:drawableStart="@drawable/ic_globe_small"
                android:drawablePadding="6dp"
                android:padding="8dp"
                android:text="English"
                android:textColor="#202124"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Visualizer Placeholder (Center) -->
            <LinearLayout
                android:id="@+id/visualizerContainer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="8dp">
                <!-- You can implement a custom View here for animation -->
                <View style="@style/VoiceBar" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                <View style="@style/VoiceBar" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                <View style="@style/VoiceBar" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                <View style="@style/VoiceBar" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
            </LinearLayout>

            <!-- Stop Button (36dp) -->
            <ImageButton
                android:id="@+id/btnStopVoice"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_red"
                android:src="@drawable/ic_stop"
                android:scaleType="center"
                app:tint="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>

    <!-- CONTAINER: KEY GRID -->
    <LinearLayout
        android:id="@+id/keyGridContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/topAreaContainer">

        <!-- ROW 1 -->
        <LinearLayout style="@style/KeyboardRow">
            <Button style="@style/KeyButton" android:text="q" />
            <Button style="@style/KeyButton" android:text="w" />
            <Button style="@style/KeyButton" android:text="e" />
            <Button style="@style/KeyButton" android:text="r" />
            <Button style="@style/KeyButton" android:text="t" />
            <Button style="@style/KeyButton" android:text="y" />
            <Button style="@style/KeyButton" android:text="u" />
            <Button style="@style/KeyButton" android:text="i" />
            <Button style="@style/KeyButton" android:text="o" />
            <Button style="@style/KeyButton" android:text="p" />
        </LinearLayout>

        <!-- ROW 2 -->
        <LinearLayout style="@style/KeyboardRow">
            <Button style="@style/KeyButton" android:text="a" />
            <Button style="@style/KeyButton" android:text="s" />
            <Button style="@style/KeyButton" android:text="d" />
            <Button style="@style/KeyButton" android:text="f" />
            <Button style="@style/KeyButton" android:text="g" />
            <Button style="@style/KeyButton" android:text="h" />
            <Button style="@style/KeyButton" android:text="j" />
            <Button style="@style/KeyButton" android:text="k" />
            <Button style="@style/KeyButton" android:text="l" />
        </LinearLayout>

        <!-- ROW 3 (Shift, z-m, Delete) -->
        <LinearLayout style="@style/KeyboardRow">
            <Button style="@style/KeyButton.Sp" android:text="⇧" /> <!-- Shift -->
            <Button style="@style/KeyButton" android:text="z" />
            <Button style="@style/KeyButton" android:text="x" />
            <Button style="@style/KeyButton" android:text="c" />
            <Button style="@style/KeyButton" android:text="v" />
            <Button style="@style/KeyButton" android:text="b" />
            <Button style="@style/KeyButton" android:text="n" />
            <Button style="@style/KeyButton" android:text="m" />
            <Button style="@style/KeyButton.Sp" android:text="⌫" /> <!-- Delete -->
        </LinearLayout>

        <!-- ROW 4 (Bottom) -->
        <LinearLayout style="@style/KeyboardRow">
            <Button style="@style/KeyButton.Sp" android:text="123" />
            <Button style="@style/KeyButton.Small" android:text="," />
            <Button style="@style/KeyButton.Space" android:text="English" />
            <Button style="@style/KeyButton.Small" android:text="." />
            <Button style="@style/KeyButton.Enter" android:text="↵" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
